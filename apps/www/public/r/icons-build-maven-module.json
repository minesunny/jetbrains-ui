      "content": "import type { FC } from 'react';\nimport { cn } from '@/lib/utils';\nimport { type IconProps, type SvgProps, sizeMap } from '../types';\n\nexport type MavenModuleProps = IconProps;\n\nconst MavenModuleLight: FC<SvgProps> = ({\n  size,\n  className,\n  title,\n  role,\n  'aria-label': ariaLabel,\n  'aria-hidden': ariaHidden,\n}) => (\n  <svg\n    width={size}\n    height={size}\n    viewBox=\"0 0 16 16\"\n    fill=\"none\"\n    xmlns=\"http://www.w3.org/2000/svg\"\n    className={className}\n    role={role}\n    aria-label={ariaLabel}\n    aria-hidden={ariaHidden}\n  >\n    {title ? <title>{title}</title> : null}\n    <path\n      d=\"M1 3.867C1 2.836 1.784 2 2.75 2h3.288a1 1 0 0 1 .698.283L8.5 4H13a2 2 0 0 1 2 2v4.008a3.502 3.502 0 0 0-1.983.446c-.377-.298-.84-.437-1.333-.45a3.34 3.34 0 0 0-1.54.298 1.5 1.5 0 0 0-.476-.181c-.744-.151-1.543.293-1.724 1.1v.002L7.316 14H2.75C1.784 14 1 13.164 1 12.133z\"\n      fill=\"#EBECF0\"\n    />\n    <path\n      d=\"M8.094 5 6.038 3H2.75c-.354 0-.75.326-.75.867v8.266c0 .54.396.867.75.867h4.792l-.226 1H2.75C1.784 14 1 13.164 1 12.133V3.867C1 2.836 1.784 2 2.75 2h3.288a1 1 0 0 1 .698.283L8.5 4H13a2 2 0 0 1 2 2v4.008a3.846 3.846 0 0 0-1 .072V6a1 1 0 0 0-1-1z\"\n      fill=\"#6C707E\"\n    />\n    <path\n      d=\"M14.796 11c1.137 0 1.334.958 1.137 1.82l-.634 2.824a.463.463 0 0 1-.548.342.44.44 0 0 1-.358-.523l.591-2.642c.315-1.368-1.469-1.2-2.192-.184l-.682 3.01a.463.463 0 0 1-.58.334.44.44 0 0 1-.336-.518l.594-2.644c.144-.618-.152-.922-.582-.975-.512-.055-1.213.247-1.604.796l-.686 3.01a.463.463 0 0 1-.55.34.44.44 0 0 1-.356-.523l.91-4.026c.053-.239.299-.391.55-.34.283.057.4.318.346.569.523-.413 1.133-.705 1.83-.667.681.014 1.014.38 1.123.86.627-.538 1.158-.862 2.027-.862\"\n      fill=\"#3574F0\"\n    />\n  </svg>\n);\n\nconst MavenModuleDark: FC<SvgProps> = ({\n  size,\n  className,\n  title,\n  role,\n  'aria-label': ariaLabel,\n  'aria-hidden': ariaHidden,\n}) => (\n  <svg\n    width={size}\n    height={size}