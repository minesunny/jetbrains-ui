{
  "name": "jetbrains-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm registry:build:ci && next build",
    "dev": "CHOKIDAR_USEPOLLING=1 WATCHPACK_POLLING=true next dev",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "registry:build:ci": "tsx ./scripts/build-registry.mts",
    "registry:build": "pnpm format:write && tsx ./scripts/build-registry.mts && pnpm format:write",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@workspace/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fumadocs-core": "15.6.3",
    "fumadocs-mdx": "11.6.10",
    "fumadocs-ui": "15.6.3",
    "lucide-react": "^0.547.0",
    "motion": "^12.23.24",
    "next": "15.3.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.6.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-resizable-panels": "^4.7.5",
    "react-use-measure": "^2.1.7",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "rimraf": "^6.0.1",
    "shiki": "^3.2.1",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.19.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.34.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
