{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tree/dynamic-tree",
  "type": "registry:ui",
  "title": "Dynamic Tree",
  "description": "JetBrains-style tree presenter for items created with @headless-tree.",
  "dependencies": [
    "@headless-tree/core",
    "@headless-tree/react"
  ],
  "registryDependencies": [
    "utils",
    "scroll-area",
    "context-menu",
    "icons-components"
  ],
  "files": [
    {
      "path": "registry/components/tree/dynamic-tree/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/tree/dynamic-tree/index.tsx"
    },
    {
      "path": "registry/components/tree/dynamic-tree/feature.ts",
      "type": "registry:lib",
      "target": "components/jetbrains-ui/tree/dynamic-tree/feature.ts"
    },
    {
      "path": "registry/components/tree/dynamic-tree/index.css",
      "type": "registry:style",
      "target": "components/jetbrains-ui/tree/dynamic-tree/index.css"
    }
  ],
  "meta": {
    "keywords": [
      "dynamic-tree",
      "tree",
      "navigation",
      "jetbrains",
      "ui",
      "component"
    ],
    "category": "navigation",
    "docs": {
      "description": "JetBrains-style tree view that renders headless-tree items with a shared visual style.",
      "features": [
        "Render items from user-defined @headless-tree setup",
        "Generic item typing for tree node data",
        "Custom item prop support for different row types",
        "Recommended asyncDataLoaderFeature with refreshable item cache",
        "Loading and disclosure states for async trees",
        "Built-in item context menu with refresh and delete actions",
        "Token-driven light/dark theme support"
      ]
    }
  }
}
