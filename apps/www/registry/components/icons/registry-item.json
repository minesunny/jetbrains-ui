{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "icons-components",
  "type": "registry:ui",
  "title": "Component Icons",
  "description": "Shared icon primitives used by JetBrains UI components.",
  "dependencies": [],
  "registryDependencies": ["utils"],
  "files": [
    {
      "path": "registry/components/icons/index.ts",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/index.ts"
    },
    {
      "path": "registry/components/icons/icons.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/icons.tsx"
    }
  ],
  "meta": {
    "keywords": ["icons", "jetbrains", "ui", "component"],
    "category": "icons",
    "docs": {
      "description": "Shared icon primitives used by core JetBrains UI components.",
      "features": [
        "Lightweight inline SVG icons",
        "Shared sizing API",
        "CurrentColor-based styling",
        "Works as an internal dependency for registry components"
      ]
    }
  }
}
