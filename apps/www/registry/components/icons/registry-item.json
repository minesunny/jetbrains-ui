{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "icons-components",
  "type": "registry:ui",
  "title": "Component Icons",
  "description": "Sprite-based icon helpers.",
  "dependencies": ["next-themes"],
  "files": [
    {
      "path": "registry/components/icons/index.ts",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/index.ts"
    },
    {
      "path": "registry/components/icons/icon/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/icon.tsx"
    },
    {
      "path": "registry/components/icons/categories.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/categories.tsx"
    },
    {
      "path": "registry/components/icons/general.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general.tsx"
    }
  ],
  "meta": {
    "keywords": ["icons", "jetbrains", "ui", "component"],
    "category": "icons",
    "docs": {
      "description": "Sprite-based icon entrypoints for JetBrains SVG sprites.",
      "features": [
        "Full-path sprite icon lookup",
        "Theme-aware SVG helper",
        "Top-category sprite files",
        "Top-category convenience wrappers"
      ]
    }
  }
}
