{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "demo-tabs",
  "type": "registry:ui",
  "title": "Tabs Demo",
  "description": "标签页组件的演示",
  "dependencies": ["@radix-ui/react-tabs"],
  "registryDependencies": ["@jetbrains-ui/tabs"],
  "files": [
    {
      "path": "registry/demo/components/tabs/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/demo/tabs.tsx"
    }
  ],
  "meta": {
    "demoProps": {
      "Tabs": {
        "orientation": {
          "value": "horizontal",
          "options": {
            "horizontal": "horizontal",
            "vertical": "vertical"
          }
        }
      }
    }
  }
}
