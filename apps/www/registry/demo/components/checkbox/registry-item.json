{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "demo-checkbox",
  "type": "registry:ui",
  "title": "Checkbox Demo",
  "description": "复选框组件的演示",
  "dependencies": ["@radix-ui/react-checkbox"],
  "registryDependencies": ["@jetbrains-ui/checkbox"],
  "files": [
    {
      "path": "registry/demo/components/checkbox/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/demo/checkbox.tsx"
    }
  ],
  "meta": {
    "demoProps": {
      "Checkbox": {
        "state": {
          "value": "unchecked",
          "options": {
            "unchecked": "unchecked",
            "checked": "checked",
            "indeterminate": "indeterminate"
          }
        },
        "disabled": {
          "value": false
        },
        "indeterminate": {
          "value": false
        },
        "invalid": {
          "value": false
        }
      }
    }
  }
}
