{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "icons-terminal",
  "type": "registry:ui",
  "title": "Terminal Icons",
  "description": "All 4 icons from the Terminal category.",
  "registryDependencies": [
    "icons-terminal-types",
    "icons-components"
  ],
  "files": [
    {
      "path": "registry/icons/terminal/index.ts",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/terminal/index.ts"
    },
    {
      "path": "public/icons/terminal.svg",
      "type": "registry:ui",
      "target": "public/icons/terminal.svg"
    }
  ],
  "meta": {
    "keywords": [
      "icons",
      "terminal",
      "jetbrains",
      "icon-pack"
    ]
  }
}
