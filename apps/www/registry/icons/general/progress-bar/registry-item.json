{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "icons-general-progress-bar",
  "type": "registry:ui",
  "title": "General Progress Bar Icons",
  "description": "All 6 icons from the General Progress Bar category.",
  "registryDependencies": [
    "icons-general-types"
  ],
  "files": [
    {
      "path": "registry/icons/general/progress-bar/index.ts",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/progress-bar/index.ts"
    },
    {
      "path": "registry/icons/general/progress-bar/pause/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/progress-bar/pause/index.tsx"
    },
    {
      "path": "registry/icons/general/progress-bar/pause-hovered/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/progress-bar/pause-hovered/index.tsx"
    },
    {
      "path": "registry/icons/general/progress-bar/resume/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/progress-bar/resume/index.tsx"
    },
    {
      "path": "registry/icons/general/progress-bar/resume-hovered/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/progress-bar/resume-hovered/index.tsx"
    },
    {
      "path": "registry/icons/general/progress-bar/stop/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/progress-bar/stop/index.tsx"
    },
    {
      "path": "registry/icons/general/progress-bar/stop-hovered/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/progress-bar/stop-hovered/index.tsx"
    }
  ],
  "meta": {
    "keywords": [
      "icons",
      "general",
      "progress-bar",
      "jetbrains",
      "icon-pack"
    ]
  }
}
