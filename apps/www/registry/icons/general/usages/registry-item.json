{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "icons-general-usages",
  "type": "registry:ui",
  "title": "General Usages Icons",
  "description": "All 4 icons from the General Usages category.",
  "registryDependencies": [
    "icons-general-types"
  ],
  "files": [
    {
      "path": "registry/icons/general/usages/index.ts",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/usages/index.ts"
    },
    {
      "path": "registry/icons/general/usages/filterdups/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/usages/filterdups/index.tsx"
    },
    {
      "path": "registry/icons/general/usages/show-import-statements/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/usages/show-import-statements/index.tsx"
    },
    {
      "path": "registry/icons/general/usages/show-read-access/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/usages/show-read-access/index.tsx"
    },
    {
      "path": "registry/icons/general/usages/show-write-access/index.tsx",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/usages/show-write-access/index.tsx"
    }
