{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "icons-general-windows",
  "type": "registry:ui",
  "title": "General Windows Icons",
  "description": "All 16 icons from the General Windows category.",
  "registryDependencies": [
    "icons-general-types",
    "icons-components"
  ],
  "files": [
    {
      "path": "registry/icons/general/windows/index.ts",
      "type": "registry:ui",
      "target": "components/jetbrains-ui/icons/general/windows/index.ts"
    },
    {
      "path": "public/icons/general.svg",
      "type": "registry:ui",
      "target": "public/icons/general.svg"
    }
  ],
  "meta": {
    "keywords": [
      "icons",
      "general",
      "windows",
      "jetbrains",
      "icon-pack"
    ]
  }
}
